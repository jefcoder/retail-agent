# RetailBench — local environment
# Copy to .env and fill in values:
#   cp .env.example .env

# === Inference (required for `docker compose --profile test run test`) ===
OPENROUTER_API_KEY=

# === Compose / images ===
# Tag for pulled images (search-server, proxy) and for locally built sandbox
IMAGE_TAG=latest
# Sandbox image used by `docker compose --profile test run test` (must match a
# locally built image: `docker compose build sandbox` from this directory).
SANDBOX_IMAGE=retailbench-sandbox:${IMAGE_TAG:-latest}

# === Search server ===
JAVA_OPTS=-Xmx8g -Xms4g
HOST=0.0.0.0
PORT=5632

# === Proxy ===
PROXY_PORT=8080
SEARCH_SERVER_URL=search-server
SEARCH_SERVER_PORT=5632
OPENROUTER_HOST=openrouter.ai
