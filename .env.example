# RetailBench — local environment
# Copy to .env and fill in values:
#   cp .env.example .env

# === Inference (required for `docker compose --profile test run test`) ===
OPENROUTER_API_KEY=

# === Compose / images ===
# Tag for pulled images (search-server, proxy, sandbox) when not building locally
IMAGE_TAG=stable
# Sandbox image used by the test runner when it spawns `docker run`
SANDBOX_IMAGE=ghcr.io/oro-ai/oro/sandbox:${IMAGE_TAG:-stable}

# === Search server ===
JAVA_OPTS=-Xmx8g -Xms4g
HOST=0.0.0.0
PORT=5632

# === Proxy ===
PROXY_PORT=8080
SEARCH_SERVER_URL=search-server
SEARCH_SERVER_PORT=5632
OPENROUTER_HOST=openrouter.ai
